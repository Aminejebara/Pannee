{
  "expo": {
    "owner": "badboiismad",
    "name": "Panne",
    "slug": "Panne",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icons/full_splash_screen_image_for_ios._centered_luxury_gold_car_icon_with_p_emblem.png",
    "scheme": "panne",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icons/full_splash_screen_image_for_ios._centered_luxury_gold_car_icon_with_p_emblem.png",
      "bundleIdentifier": "com.badboiismad.Panne",
      "config": {
        "googleMapsApiKey": "AIzaSyAmnxE-yT8o9qhOUyWfPfSE6S1vgO8DrjI"
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Acces a vos photos pour votre photo de profil.",
        "NSCameraUsageDescription": "Acces a votre camera pour votre photo de profil.",
        "NSLocationWhenInUseUsageDescription": "Cette application a besoin de votre position pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Cette application a besoin de votre position en arriere-plan pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
        "NSLocationAlwaysUsageDescription": "Cette application a besoin de votre position en arriere-plan pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
        "UIBackgroundModes": [
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "versionCode": 31,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "backgroundImage": "./assets/icons/android_background_android_background.png",
        "foregroundImage": "./assets/icons/full_splash_screen_image_for_ios._centered_luxury_gold_car_icon_with_p_emblem.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alayadigital.panne_auto",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAmnxE-yT8o9qhOUyWfPfSE6S1vgO8DrjI"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/full_splash_screen_image_for_ios._centered_luxury_gold_car_icon_with_p_emblem.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application accede a vos photos pour votre photo de profil.",
          "cameraPermission": "L'application accede a votre camera pour votre photo de profil.",
          "microphonePermission": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.140902347206-6sjvsv9kdok2cam2722e44b8ic4pg6h5",
          "androidClientId": "140902347206-fqoh6cvs39lf3qupl2t7o4p6csc29k0q.apps.googleusercontent.com"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Cette application a besoin de votre position en arriere-plan pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
          "locationAlwaysPermission": "Cette application a besoin de votre position en arriere-plan pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
          "locationWhenInUsePermission": "Cette application a besoin de votre position pour mettre a jour votre localisation et permettre aux clients de vous trouver.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFD200",
          "sounds": [
            "./assets/sounds/notification.wav"
          ],
          "androidMode": "default",
          "androidCollapsedTitle": "Nouveau message",
          "iosDisplayInForeground": true
        }
      ],
      "./plugins/withPodfile.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "855dec4c-0081-4aa7-9122-2db51ec6a4e8"
      }
    }
  }
}